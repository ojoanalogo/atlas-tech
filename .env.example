# Database
# For local docker-compose: postgresql://atlas:atlas_local@localhost:5432/atlas
# For Neon production: postgresql://user:pass@host.neon.tech/dbname?sslmode=require
DATABASE_URI=postgresql://atlas:atlas_local@localhost:5432/atlas

# Payload
PAYLOAD_SECRET=generate-a-random-32-char-string

# S3 storage (MinIO local / Cloudflare R2 production)
# For local docker-compose:
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=atlas-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
# For Cloudflare R2 production:
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto

# Public URL for media
# For local: http://localhost:9000/atlas-media
# For production: https://media.atlas-sinaloa.tech
MEDIA_URL=http://localhost:9000/atlas-media

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# better-auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Wallet Pass Generation ---
APPLE_PASS_TYPE_ID=pass.tech.atlas-sinaloa
APPLE_TEAM_ID=E6NEQGYHTR

# Option A: File paths (local dev)
APPLE_PASS_CERT_PATH=certs/pass.pem
APPLE_PASS_KEY_PATH=certs/pass-key.pem
APPLE_WWDR_CERT_PATH=certs/wwdr.pem

# Option B: Base64-encoded contents (Docker / Coolify)
# Generate with: cat certs/pass.pem | base64 -w 0
# APPLE_PASS_CERT_B64=
# APPLE_PASS_KEY_B64=
# APPLE_WWDR_CERT_B64=

GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CLASS_ID=atlastech.profile-card

# Option A: File path (local dev)
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=certs/google-sa.json

# Option B: Base64-encoded JSON (Docker / Coolify)
# Generate with: cat certs/google-sa.json | base64 -w 0
# GOOGLE_WALLET_SA_B64=
