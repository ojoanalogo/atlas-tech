---
import { SINALOA_MUNICIPALITIES } from "../config";
import SinaloaMap from "./maps/SinaloaMap";

interface Props {
  municipalityCounts: Record<string, number>;
}

const { municipalityCounts } = Astro.props;
---

<section id="map" class="py-8 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-sans font-bold text-primary">
        Mapa del ecosistema
      </h2>
      <p class="mt-2 text-secondary">
        Visualiza la distribución del talento tech en Sinaloa
      </p>
    </div>

    <div class="grid lg:grid-cols-[280px_1fr] gap-4">
      {/* Sidebar - Municipalities */}
      <div
        class="bg-card/90 backdrop-blur-sm border border-border rounded-lg p-4 space-y-2 lg:max-h-[500px] overflow-y-auto"
      >
        <button
          id="municipalities-toggle"
          type="button"
          class="w-full flex items-center justify-between lg:pointer-events-none"
        >
          <h3 class="font-mono text-xs text-muted uppercase tracking-wider">
            Municipios
          </h3>
          <svg
            class="w-4 h-4 text-muted transition-transform duration-200 lg:hidden"
            id="municipalities-chevron"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="municipalities-list" class="hidden lg:block space-y-1">
          {
            SINALOA_MUNICIPALITIES.map((mun) => {
              const count = municipalityCounts[mun.id] || 0;
              return (
                <button
                  type="button"
                  data-municipality={mun.id}
                  class="w-full flex items-center justify-between py-2 px-3 rounded hover:bg-elevated transition-colors text-left cursor-pointer data-[active]:bg-elevated data-[active]:border-l-2 data-[active]:border-accent"
                >
                  <span class="text-sm text-primary">{mun.name}</span>
                  <span class="text-xs font-mono text-muted">{count}</span>
                </button>
              );
            })
          }
        </div>
      </div>

      {/* Map */}
      <div
        class="h-[500px] bg-card border border-border rounded-lg overflow-hidden"
      >
        <SinaloaMap municipalityCounts={municipalityCounts} client:visible />
      </div>
    </div>
  </div>
</section>

<script>
  // Municipalities collapsible toggle
  const munToggle = document.getElementById("municipalities-toggle");
  const munList = document.getElementById("municipalities-list");
  const munChevron = document.getElementById("municipalities-chevron");

  if (munToggle && munList && munChevron) {
    munToggle.addEventListener("click", () => {
      const isOpen = !munList.classList.contains("hidden");
      if (isOpen) {
        munList.classList.add("hidden");
        munList.classList.remove("lg:block");
        munChevron.classList.remove("rotate-180");
      } else {
        munList.classList.remove("hidden");
        munList.classList.add("lg:block");
        munChevron.classList.add("rotate-180");
      }
    });
  }

  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-municipality]");
  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.dataset.municipality;
      // Toggle active state
      const wasActive = btn.hasAttribute("data-active");
      buttons.forEach((b) => b.removeAttribute("data-active"));
      if (!wasActive) {
        btn.setAttribute("data-active", "");
        window.dispatchEvent(new CustomEvent("select-municipality", { detail: { id } }));
      }
    });
  });

  // Clear active state when map popup is closed
  window.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest("[data-municipality]") && !target.closest("[data-map-popup]")) {
      buttons.forEach((b) => b.removeAttribute("data-active"));
    }
  });
</script>
