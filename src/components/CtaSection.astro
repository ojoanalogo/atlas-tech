<section class="py-4 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <div class="bg-card border border-border rounded-lg p-8 md:p-12 space-y-6">
      <h2 class="text-2xl md:text-3xl font-sans font-bold text-primary">
        REGISTRA TU PROYECTO
      </h2>
      <p class="text-secondary max-w-lg mx-auto">
        Forma parte del directorio tech más completo de Sinaloa. Da a conocer tu
        startup, consultoría, comunidad o perfil profesional.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="/directorio/submit"
          class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-accent-foreground font-mono font-semibold text-sm rounded-lg hover:bg-accent/90 transition-colors"
        >
          AGREGAR PROYECTO
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 4v16m8-8H4"></path>
          </svg>
        </a>
        <a
          href="/directorio"
          class="inline-flex items-center gap-2 px-6 py-3 border border-border text-primary font-mono font-semibold text-sm rounded-lg hover:border-accent/50 hover:text-accent transition-colors"
        >
          EXPLORAR DIRECTORIO
        </a>
      </div>
    </div>
  </div>
</section>
