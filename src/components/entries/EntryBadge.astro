---
import { ENTRY_TYPE_CONFIG, type AtlasEntryType } from "../../config";

interface Props {
  type: AtlasEntryType;
  class?: string;
}

const { type, class: className = "" } = Astro.props;

const config = ENTRY_TYPE_CONFIG[type];
---

<span
  class:list={[
    "inline-flex items-center px-2 py-0.5 rounded text-xs font-mono border",
    config.badgeColor,
    className,
  ]}
>
  {config.label}
</span>
