---
import type { CollectionEntry } from "astro:content";
import EntryCard from "./EntryCard.astro";

interface Props {
  entries: CollectionEntry<"atlas">[];
}

const { entries } = Astro.props;
const BASE = import.meta.env.BASE_URL;
---

{
  entries.length > 0 && (
    <section class="py-4 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-10">
          <div>
            <h2 class="text-2xl md:text-3xl font-sans font-bold text-primary">
              Destacados
            </h2>
            <p class="mt-2 text-secondary">
              Proyectos y organizaciones destacadas del ecosistema
            </p>
          </div>
          <a
            href={`${BASE}/directorio`}
            class="hidden sm:inline-flex items-center gap-2 text-sm font-mono text-accent hover:underline"
          >
            VER TODOS
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"
              />
            </svg>
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {entries.slice(0, 6).map((entry) => (
            <EntryCard
              slug={entry.slug}
              name={entry.data.name}
              tagline={entry.data.tagline}
              entryType={entry.data.entryType}
              logo={entry.data.logo}
              coverImage={entry.data.coverImage}
              municipality={entry.data.municipality}
              city={entry.data.city}
              tags={entry.data.tags}
            />
          ))}
        </div>
      </div>
    </section>
  )
}
