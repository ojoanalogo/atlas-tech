---
import { Image } from "astro:assets";
import { getMunicipalityName, getEntryUrl, type AtlasEntryType } from "../config";
import EntryBadge from "./EntryBadge.astro";
import { MapPin } from "@lucide/astro";

interface Props {
  slug: string;
  name: string;
  tagline?: string;
  entryType: AtlasEntryType;
  logo?: ImageMetadata;
  coverImage?: ImageMetadata;
  municipality: string;
  city: string;
  tags?: string[];
}

const {
  slug,
  name,
  tagline,
  entryType,
  logo,
  coverImage,
  municipality,
  city,
  tags = [],
} = Astro.props;
---

<a
  href={getEntryUrl(entryType, slug)}
  class="group block bg-card/90 backdrop-blur-sm border border-border rounded-lg overflow-hidden hover:border-accent/50 transition-all duration-300"
>
  {/* Cover image */}
  <div class="h-36 bg-elevated relative overflow-hidden">
    {
      coverImage ? (
        <Image
          src={coverImage}
          alt={name}
          widths={[320, 480]}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center">
          {logo ? (
            <Image
              src={logo}
              alt={`${name} logo`}
              width={64}
              height={64}
              class="w-16 h-16 object-contain"
            />
          ) : (
            <span class="text-4xl font-mono text-muted/30 font-bold">
              {name.charAt(0).toUpperCase()}
            </span>
          )}
        </div>
      )
    }
    <div class="absolute top-2 left-2">
      <EntryBadge type={entryType} />
    </div>
  </div>

  {/* Content */}
  <div class="p-4 space-y-2">
    <div class="flex items-center gap-2">
      {
        logo && coverImage && (
          <Image
            src={logo}
            alt={`${name} logo`}
            width={24}
            height={24}
            class="w-6 h-6 rounded border border-border object-cover shrink-0"
          />
        )
      }
      <h3
        class="font-sans font-semibold text-primary group-hover:text-accent transition-colors truncate"
      >
        {name}
      </h3>
    </div>
    {tagline && <p class="text-sm text-secondary line-clamp-2">{tagline}</p>}
    <div class="flex items-center gap-1 text-xs text-muted">
      <MapPin class="w-3 h-3 shrink-0" />
      <span>{municipality === "global" ? city : `${city}, ${getMunicipalityName(municipality)}`}</span>
    </div>
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1 pt-1">
          {tags.slice(0, 3).map((tag) => (
            <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-elevated text-muted">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </div>
</a>
