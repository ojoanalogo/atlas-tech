---
import { SITE_TITLE, NAV_LINKS, SOCIAL_LINKS } from "../../config";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-card mt-4">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {/* Brand */}
      <div class="space-y-3">
        <div class="font-mono font-bold text-lg text-primary">
          TECH<span class="text-accent">_</span>ATLAS
        </div>
        <p class="text-sm text-muted">
          Directorio del ecosistema tecnológico de Sinaloa, México.
        </p>
      </div>

      {/* Navigation */}
      <div>
        <h4 class="font-mono text-xs text-muted uppercase tracking-wider mb-3">
          Directorio
        </h4>
        <ul class="space-y-2">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.url}
                  class="text-sm text-secondary hover:text-accent transition-colors"
                >
                  {link.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Links */}
      <div>
        <h4 class="font-mono text-xs text-muted uppercase tracking-wider mb-3">
          Recursos
        </h4>
        <ul class="space-y-2">
          <li>
            <a
              href="/directorio"
              class="text-sm text-secondary hover:text-accent transition-colors"
            >
              Explorar
            </a>
          </li>
          <li>
            <a
              href="/#map"
              class="text-sm text-secondary hover:text-accent transition-colors"
            >
              Mapa
            </a>
          </li>
        </ul>
      </div>

      {/* Social */}
      <div>
        <h4 class="font-mono text-xs text-muted uppercase tracking-wider mb-3">
          Social
        </h4>
        <ul class="space-y-2">
          {
            SOCIAL_LINKS.map((link) => (
              <li>
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-secondary hover:text-accent transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="border-t border-border mt-8 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <p class="text-xs text-muted font-mono">
        &copy; {currentYear}
        {SITE_TITLE}. Hecho en Sinaloa.
      </p>
      <p class="text-xs text-muted font-mono">
        Construido con Astro + Tailwind
      </p>
    </div>
  </div>
</footer>
