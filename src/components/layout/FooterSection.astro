---
import { SITE_TITLE, NAV_LINKS } from "../../config";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-card mt-4">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {/* Brand + Open Source CTA */}
      <div class="space-y-3">
        <div class="font-mono font-bold text-lg text-primary uppercase">
          Tech<span class="text-accent">_</span>Atlas
        </div>
        <p class="text-sm text-muted">
          Directorio del ecosistema tecnológico de Sinaloa, México.
        </p>
        <p class="text-sm text-muted">
          Este proyecto es código abierto. Crea el atlas de tu estado.
        </p>
        <a
          href="https://github.com/ojoanalogo/atlas-tech"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-accent text-accent-foreground font-mono font-bold text-xs rounded hover:bg-accent/90 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          Construye tu propio atlas
        </a>
      </div>

      {/* Navigation */}
      <div>
        <h4 class="font-mono text-xs text-muted uppercase tracking-wider mb-3">
          Directorio
        </h4>
        <ul class="space-y-2">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.url}
                  class="text-sm text-secondary hover:text-accent transition-colors"
                >
                  {link.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Links */}
      <div>
        <h4 class="font-mono text-xs text-muted uppercase tracking-wider mb-3">
          Recursos
        </h4>
        <ul class="space-y-2">
          <li>
            <a
              href="/directorio"
              class="text-sm text-secondary hover:text-accent transition-colors"
            >
              Explorar
            </a>
          </li>
          <li>
            <a
              href="/#map"
              class="text-sm text-secondary hover:text-accent transition-colors"
            >
              Mapa
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="border-t border-border mt-8 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <p class="text-xs text-muted font-mono">
        &copy; {currentYear}
        {SITE_TITLE}. Hecho en Sinaloa.
      </p>
      <p class="text-xs text-muted font-mono">
        Construido con Astro + Tailwind
      </p>
    </div>
  </div>
</footer>
