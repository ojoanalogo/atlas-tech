---
import ThemeToggle from "../ui/ThemeToggle.tsx";
import "../../styles/tooltip.css";
import { ENTRY_TYPE_CONFIG, ENTRY_TYPES } from "../../config";

const directoryLinks = ENTRY_TYPES.map((type) => ({
  title: ENTRY_TYPE_CONFIG[type].labelPlural,
  url: `/${ENTRY_TYPE_CONFIG[type].slug}`,
}));
---

<header id="main-header" class="px-4 py-4">
  <div class:list={["mx-auto", "max-w-7xl"]}>
    <div
      class="bg-white dark:bg-card border rounded-lg font-mono text-sm transition-all duration-300 border-gray-400/50 dark:border-gray-400/30 hover:shadow-xs dark:hover:shadow-md dark:hover:shadow-black/20"
    >
      <nav
        id="navigation-menu"
        aria-label="Menú principal"
        class="flex items-center justify-between gap-4 px-4 py-3"
      >
        {/* Logo */}
        <a
          href="/"
          class="font-sans font-bold text-primary hover:text-accent transition-colors duration-200 shrink-0 uppercase"
        >
          Sinaloa Tech<span class="text-accent">_</span>Atlas
        </a>

        {/* Desktop nav links */}
        <div class="hidden sm:flex items-center gap-4 text-xs overflow-visible">
          {/* Directory dropdown */}
          <div class="relative" data-dropdown data-dropdown-hover>
            <button
              type="button"
              data-dropdown-toggle
              class="flex items-center gap-1 text-secondary hover:text-accent transition-all duration-200"
              aria-expanded="false"
              aria-haspopup="true"
            >
              Directorio
              <svg
                class="w-3 h-3 transition-transform duration-200"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div
              data-dropdown-menu
              class="absolute top-full left-0 pt-2 w-44 hidden z-50"
            >
              <div
                class="py-1 bg-white dark:bg-[#0a0a0a] border border-border rounded-lg shadow-xl"
              >
                <a
                  href="/directorio"
                  class="block px-3 py-2.5 text-xs font-mono text-primary hover:text-accent hover:bg-elevated transition-colors"
                >
                  Ver todos
                </a>
                <div class="border-t border-border my-1"></div>
                {
                  directoryLinks.map((link) => (
                    <a
                      href={link.url}
                      class="block px-3 py-2.5 text-xs font-mono text-secondary hover:text-accent hover:bg-elevated transition-colors"
                    >
                      {link.title}
                    </a>
                  ))
                }
              </div>
            </div>
          </div>

          <a
            href="/eventos"
            class="text-secondary hover:text-accent transition-all duration-200"
          >
            Eventos
          </a>

          <a
            href="/#map"
            class="text-secondary hover:text-accent transition-all duration-200"
          >
            Mapa
          </a>

          <a
            href="/directorio/submit"
            class="inline-flex items-center gap-1.5 px-3 py-2.5 min-h-11 bg-accent text-accent-foreground font-mono font-semibold text-xs rounded hover:bg-accent/90 transition-colors"
          >
            Agregar proyecto
          </a>

          <ThemeToggle client:load />
        </div>

        {/* Mobile: theme toggle + hamburger */}
        <div class="flex items-center gap-2 sm:hidden">
          <ThemeToggle client:load />
          <button
            id="mobile-menu-toggle"
            type="button"
            class="p-2 min-h-11 min-w-11 flex items-center justify-center text-secondary hover:text-accent transition-colors"
            aria-expanded="false"
            aria-label="Abrir menú"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </nav>
    </div>
  </div>
</header>

{/* Mobile fullscreen menu overlay */}
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
  class="fixed inset-0 z-100 bg-background flex flex-col opacity-0 invisible transition-all duration-300 sm:hidden"
>
  <div class="flex items-center justify-between px-8 py-6">
    <a href="/" class="font-mono font-bold text-primary uppercase">
      Sinaloa Tech<span class="text-accent">_</span>Atlas
    </a>
    <button
      id="mobile-menu-close"
      type="button"
      class="p-2 min-h-11 min-w-11 flex items-center justify-center text-secondary hover:text-accent transition-colors"
      aria-label="Cerrar menú"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div class="flex-1 flex flex-col justify-center px-8 space-y-2 uppercase">
    <a
      href="/directorio"
      class="block py-3 text-lg font-mono font-semibold text-primary hover:text-accent transition-colors"
    >
      Directorio
    </a>
    <div class="pl-4 space-y-1 border-l-2 border-border">
      {
        directoryLinks.map((link) => (
          <a
            href={link.url}
            class="block py-2 text-sm font-mono text-secondary hover:text-accent transition-colors"
          >
            {link.title}
          </a>
        ))
      }
    </div>
    <a
      href="/eventos"
      class="block py-3 text-lg font-mono font-semibold text-primary hover:text-accent transition-colors"
    >
      Eventos
    </a>
    <a
      href="/#map"
      class="block py-3 text-lg font-mono font-semibold text-primary hover:text-accent transition-colors"
    >
      Mapa
    </a>
    <div class="pt-4">
      <a
        href="/directorio/submit"
        class="inline-flex items-center gap-2 px-5 py-3 bg-accent text-accent-foreground font-mono font-bold text-sm rounded hover:bg-accent/90 transition-colors"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4v16m8-8H4"></path>
        </svg>
        Agregar proyecto
      </a>
    </div>
  </div>
</div>

<script>
  // --- Mobile menu (event delegation for resize resilience) ---
  function openMenu() {
    const mobileMenu = document.getElementById("mobile-menu");
    if (!mobileMenu) return;
    mobileMenu.classList.remove("opacity-0", "invisible");
    mobileMenu.classList.add("opacity-100", "visible");
    document.body.style.overflow = "hidden";
    document
      .getElementById("mobile-menu-toggle")
      ?.setAttribute("aria-expanded", "true");
  }

  function closeMenu() {
    const mobileMenu = document.getElementById("mobile-menu");
    if (!mobileMenu) return;
    mobileMenu.classList.add("opacity-0", "invisible");
    mobileMenu.classList.remove("opacity-100", "visible");
    document.body.style.overflow = "";
    document
      .getElementById("mobile-menu-toggle")
      ?.setAttribute("aria-expanded", "false");
  }

  document.addEventListener("click", (e) => {
    const target = e.target as Element;
    if (target.closest("#mobile-menu-toggle")) {
      openMenu();
      return;
    }
    if (target.closest("#mobile-menu-close")) {
      closeMenu();
      return;
    }
    if (target.closest("#mobile-menu a")) {
      closeMenu();
    }
  });

  // --- Generic dropdown system ---
  // Uses: data-dropdown (container), data-dropdown-toggle (button),
  //       data-dropdown-menu (panel), data-dropdown-hover (opt-in hover)

  function closeAllDropdowns() {
    document
      .querySelectorAll("[data-dropdown-menu]")
      .forEach((m) => m.classList.add("hidden"));
    document
      .querySelectorAll("[data-dropdown-toggle]")
      .forEach((t) => t.setAttribute("aria-expanded", "false"));
  }

  // Click: toggle on button, close on outside
  document.addEventListener("click", (e) => {
    const target = e.target as Element;
    const toggle = target.closest("[data-dropdown-toggle]");

    if (toggle) {
      const container = toggle.closest("[data-dropdown]");
      const menu = container?.querySelector("[data-dropdown-menu]");
      if (!menu) return;

      const wasOpen = !menu.classList.contains("hidden");
      closeAllDropdowns();

      if (!wasOpen) {
        menu.classList.remove("hidden");
        toggle.setAttribute("aria-expanded", "true");
      }
      return;
    }

    // Clicks inside an open menu — don't close
    if (target.closest("[data-dropdown-menu]")) return;

    closeAllDropdowns();
  });

  // Hover support (opt-in via data-dropdown-hover)
  document
    .querySelectorAll<HTMLElement>("[data-dropdown-hover]")
    .forEach((container) => {
      const menu = container.querySelector("[data-dropdown-menu]");
      const toggle = container.querySelector("[data-dropdown-toggle]");
      if (!menu || !toggle) return;

      let timer: ReturnType<typeof setTimeout> | null = null;

      container.addEventListener("mouseenter", () => {
        if (timer) {
          clearTimeout(timer);
          timer = null;
        }
        menu.classList.remove("hidden");
        toggle.setAttribute("aria-expanded", "true");
      });

      container.addEventListener("mouseleave", () => {
        timer = setTimeout(() => {
          menu.classList.add("hidden");
          toggle.setAttribute("aria-expanded", "false");
        }, 150);
      });
    });
</script>
