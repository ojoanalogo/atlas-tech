---
import { FAQS } from "../../config";
---

<section class="py-4 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-sans font-bold text-primary">
        Preguntas frecuentes
      </h2>
      <p class="mt-2 text-secondary">
        Todo lo que necesitas saber sobre Tech Atlas
      </p>
    </div>

    <div class="space-y-3">
      {
        FAQS.map((faq) => (
          <details class="group bg-card border border-border rounded-lg">
            <summary class="flex items-center justify-between cursor-pointer px-5 py-4 font-sans font-semibold text-primary hover:text-accent transition-colors list-none">
              <span>{faq.question}</span>
              <svg
                class="w-4 h-4 shrink-0 text-muted group-open:rotate-180 transition-transform duration-200"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </summary>
            <div class="px-5 pb-4 text-sm text-secondary leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
