---
import type { CollectionEntry } from "astro:content";
import EntryCard from "../entries/EntryCard.astro";
import FeaturedCarousel from "../entries/FeaturedCarousel";
import { getCityName } from "../../config";

interface Props {
  entries: CollectionEntry<"atlas">[];
}

const { entries } = Astro.props;

const displayEntries = entries.slice(0, 6);

const carouselEntries = displayEntries.map((entry) => ({
  slug: entry.slug,
  name: entry.data.name,
  tagline: entry.data.tagline,
  entryType: entry.data.entryType,
  logoSrc: entry.data.logo?.src,
  coverSrc: entry.data.coverImage?.src,
  city: entry.data.city,
  cityName: getCityName(entry.data.city),
  tags: entry.data.tags || [],
}));
---

{
  entries.length > 0 && (
    <section class="py-4 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-10">
          <div>
            <h2 class="text-2xl md:text-3xl font-sans font-bold text-primary">
              Destacados
            </h2>
            <p class="mt-2 text-secondary">
              Startups y organizaciones destacadas del ecosistema
            </p>
          </div>
          <a
            href="/directorio"
            class="hidden sm:inline-flex items-center gap-2 text-sm font-mono text-accent hover:underline"
          >
            VER TODOS
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"
              />
            </svg>
          </a>
        </div>

        {/* Mobile carousel */}
        <div class="sm:hidden">
          <FeaturedCarousel entries={carouselEntries} client:visible />
        </div>

        {/* Desktop grid */}
        <div class="hidden sm:grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {displayEntries.map((entry) => (
            <EntryCard
              slug={entry.slug}
              name={entry.data.name}
              tagline={entry.data.tagline}
              entryType={entry.data.entryType}
              logo={entry.data.logo}
              coverImage={entry.data.coverImage}
              city={entry.data.city}
              tags={entry.data.tags}
            />
          ))}
        </div>
      </div>
    </section>
  )
}
