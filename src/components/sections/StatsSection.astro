---
import { ENTRY_TYPE_CONFIG, type AtlasEntryType } from "../../config";
import { Database, Rocket, Users, MapPin } from "@lucide/astro";

interface Props {
  total: number;
  counts: Record<AtlasEntryType, number>;
  municipalities: number;
}

const { total, counts, municipalities } = Astro.props;

const stats = [
  { label: "Total registros", value: total, accent: true, icon: Database },
  {
    label: ENTRY_TYPE_CONFIG.startup.labelPlural,
    value: counts.startup + counts.business,
    icon: Rocket,
  },
  {
    label: ENTRY_TYPE_CONFIG.community.labelPlural,
    value: counts.community,
    icon: Users,
  },
  { label: "Municipios", value: municipalities, icon: MapPin },
];
---

<section class="py-4 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {
        stats.map((stat) => (
          <div class="bg-card border border-border rounded-lg p-5 text-center hover:border-accent/30 transition-colors">
            <div class="flex justify-center mb-2">
              <stat.icon
                class:list={[
                  "w-5 h-5",
                  stat.accent ? "text-accent" : "text-muted",
                ]}
              />
            </div>
            <div
              class:list={[
                "text-3xl md:text-4xl font-mono font-bold",
                stat.accent ? "text-accent" : "text-primary",
              ]}
            >
              {stat.value}
            </div>
            <div class="text-sm text-muted font-mono mt-1 uppercase tracking-wider">
              {stat.label}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
