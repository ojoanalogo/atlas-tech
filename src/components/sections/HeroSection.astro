---
import SinaloaMap from "../maps/SinaloaMap";
import { MapPin, Search, Plus } from "@lucide/astro";
import { SINALOA_CITIES } from "../../config";

interface Props {
  cityCounts?: Record<string, number>;
}

const { cityCounts = {} } = Astro.props;
---

<section id="hero" class="py-8 px-4">
  <div
    class="max-w-7xl lg:mx-auto flex flex-col lg:flex-row gap-16 items-center"
  >
    {/* Left: Text content */}
    <div
      class="space-y-6 flex-1 flex flex-col items-center text-center lg:items-start lg:text-left"
    >
      <div
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-accent/10 border border-accent/20"
      >
        <MapPin class="w-3.5 h-3.5 text-accent" />
        <span class="text-xs font-mono font-semibold text-accent tracking-wide"
          >// SINALOA, MÉXICO</span
        >
      </div>

      <h1
        class="text-4xl md:text-5xl lg:text-hero font-sans font-bold text-primary leading-[1.1] tracking-tight"
      >
        DESCUBRE EL ECOSISTEMA<br />
        TECNOLÓGICO DE SINALOA
      </h1>

      <p
        class="text-sm md:text-base font-mono text-muted leading-relaxed max-w-125"
      >
        Un directorio completo de startups, consultorías tech, talento y
        comunidades construyendo el futuro en nuestro estado.
      </p>

      <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
        <a
          href="/directorio"
          class="inline-flex items-center gap-2.5 px-6 py-3.5 bg-accent text-accent-foreground font-mono font-bold text-xs rounded hover:bg-accent/90 transition-colors"
        >
          <Search class="w-4 h-4" />
          EXPLORAR DIRECTORIO
        </a>
        <a
          href="/directorio/submit"
          class="inline-flex items-center gap-2.5 px-6 py-3.5 bg-card border border-border text-primary font-mono font-semibold text-xs rounded hover:border-accent/50 hover:text-accent transition-colors"
        >
          <Plus class="w-4 h-4" />
          AGREGAR PROYECTO
        </a>
      </div>
    </div>

    {/* Right: Hero Map Card */}
    <div class="hidden lg:block w-full lg:w-110 xl:w-125 shrink-0">
      <div
        class="bg-card border border-border rounded-lg p-4 flex flex-col gap-4 h-[45vh]"
      >
        {/* Map header */}
        <div class="flex items-center justify-between">
          <span class="text-xs font-mono font-medium text-muted tracking-wide"
            >// SINALOA.GEO</span
          >
          <div class="flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
            <span class="text-xs font-mono font-semibold text-accent"
              >[{SINALOA_CITIES.length} municipios]</span
            >
          </div>
        </div>

        {/* Map container */}
        <div
          class="flex-1 bg-elevated border border-border rounded overflow-hidden"
        >
          <SinaloaMap compact linkOnClick cityCounts={cityCounts} client:idle />
        </div>
      </div>
    </div>
  </div>
</section>
