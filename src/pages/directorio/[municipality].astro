---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntryCard from "../../components/entries/EntryCard.astro";
import DirectoryFilter from "../../components/entries/DirectoryFilter";
import {
  SINALOA_MUNICIPALITIES,
  ENTRY_TYPE_CONFIG,
  getMunicipalityName,
} from "../../config";

export function getStaticPaths() {
  return SINALOA_MUNICIPALITIES.map((m) => ({
    params: { municipality: m.id },
    props: { municipalityId: m.id, municipalityName: m.name },
  }));
}

const { municipalityId, municipalityName } = Astro.props;

const allEntries = await getCollection("atlas");

const typeLabels: Record<string, string> = Object.fromEntries(
  Object.entries(ENTRY_TYPE_CONFIG).map(([k, v]) => [k, v.labelPlural]),
);

const municipalityCounts: Record<string, number> = {};
allEntries.forEach((entry) => {
  const mun = entry.data.municipality;
  municipalityCounts[mun] = (municipalityCounts[mun] || 0) + 1;
});

const globalCount = municipalityCounts["global"] || 0;

const municipalities = [
  ...(globalCount > 0
    ? [{ id: "global", name: "Global", count: globalCount }]
    : []),
  ...SINALOA_MUNICIPALITIES.map((m) => ({
    id: m.id,
    name: m.name,
    count: municipalityCounts[m.id] || 0,
  })),
];
---

<BaseLayout title={`${municipalityName} — TECH_ATLAS`}>
  <section class="py-4 px-4">
    <div class="max-w-7xl mx-auto">
      <DirectoryFilter
        client:load
        typeLabels={typeLabels}
        municipalities={municipalities}
        totalCount={allEntries.length}
        initialMunicipality={municipalityId}
      >
        <div id="entries-grid" class="grid sm:grid-cols-2 xl:grid-cols-3 gap-4">
          {
            allEntries.map((entry) => (
              <div
                class="entry-item"
                data-type={entry.data.entryType}
                data-municipality={entry.data.municipality}
              >
                <EntryCard
                  slug={entry.slug}
                  name={entry.data.name}
                  tagline={entry.data.tagline}
                  entryType={entry.data.entryType}
                  logo={entry.data.logo}
                  coverImage={entry.data.coverImage}
                  municipality={entry.data.municipality}
                  city={entry.data.city}
                  tags={entry.data.tags}
                />
              </div>
            ))
          }
        </div>
      </DirectoryFilter>
    </div>
  </section>
</BaseLayout>
