---
import { getCollection } from "astro:content";
import DirectoryLayout from "../../layouts/DirectoryLayout.astro";
import { SINALOA_CITIES } from "../../config";

export function getStaticPaths() {
  return SINALOA_CITIES.map((m) => ({
    params: { city: m.id },
    props: { cityId: m.id, cityName: m.name },
  }));
}

const { cityId, cityName } = Astro.props;
const allEntries = await getCollection("atlas");
---

<DirectoryLayout
  title={`${cityName} | Tech Atlas`}
  entries={allEntries}
  cityEntries={allEntries}
  initialCity={cityId}
/>
