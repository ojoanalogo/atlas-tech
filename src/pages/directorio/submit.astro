---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SubmitWizard from "../../components/forms/SubmitWizard";
import { SINALOA_CITIES } from "../../config";

const cities = [
  { id: "global", name: "Global (sin ubicacion especifica)" },
  ...SINALOA_CITIES.map((m) => ({ id: m.id, name: m.name })),
];
---

<BaseLayout title="Agregar Proyecto | Tech Atlas">
  <section class="py-4 px-4">
    <div class="max-w-2xl mx-auto">
      {/* Breadcrumb */}
      <nav aria-label="Breadcrumb" class="text-xs font-mono text-muted mb-6 uppercase">
        <a href="/" class="hover:text-accent transition-colors">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/directorio" class="hover:text-accent transition-colors"
          >Directorio</a
        >
        <span class="mx-2">/</span>
        <span class="text-primary">Agregar proyecto</span>
      </nav>

      <h1 class="text-3xl md:text-4xl font-sans font-bold text-primary mb-2">
        Agregar proyecto
      </h1>
      <p class="text-secondary mb-8">
        Registra tu startup, consultora, comunidad o perfil en el directorio
        tech de Sinaloa.
      </p>

      <div
        class="bg-card/90 backdrop-blur-sm border border-border rounded-lg p-6 md:p-8"
      >
        <SubmitWizard client:load cities={cities} />
      </div>
    </div>
  </section>
</BaseLayout>
