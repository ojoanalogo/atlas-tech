---
import BaseLayout from "../layouts/BaseLayout.astro";
import EventsHeroSection from "../components/sections/EventsHeroSection.astro";
import CalendarSection from "../components/sections/CalendarSection.astro";
import MatrixBackground from "../components/layout/MatrixBackground.astro";
---

<BaseLayout
  title="Eventos Tech en Sinaloa | Tech Atlas"
  description="Meetups, talleres, hackatones y conferencias tech en Sinaloa, México. Conecta con la comunidad tecnológica local."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Eventos Tech en Sinaloa",
    "description": "Meetups, talleres, hackatones y conferencias tech en Sinaloa, México.",
    "url": "https://atlas-sinaloa.tech/eventos",
    "isPartOf": {
      "@type": "WebSite",
      "name": "Tech Atlas",
      "url": "https://atlas-sinaloa.tech"
    }
  })} />
  <MatrixBackground
    movementDirection="up-left"
    movementSpeed={0.04}
    highlight={false}
    slot="bg"
  />
  <EventsHeroSection />
  <CalendarSection />
</BaseLayout>
