---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  countByType,
  countByTypeAndCity,
  getFeaturedEntries,
  groupByCity,
} from "../utils";
import CalendarSection from "../components/sections/CalendarSection.astro";
import CtaSection from "../components/sections/CtaSection.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import MapSection from "../components/sections/MapSection.tsx";
import CategorySection from "../components/sections/CategorySection.astro";
import FeaturedSection from "../components/sections/FeaturedSection.astro";
import MatrixBackground from "../components/layout/MatrixBackground.astro";

const allEntries = await getCollection("atlas");
const counts = countByType(allEntries);
const featured = getFeaturedEntries(allEntries);
const cityCounts = groupByCity(allEntries);
const cityTypeCounts = countByTypeAndCity(allEntries);
---

<BaseLayout>
  <link
    slot="head"
    rel="preload"
    href="/topo/Sinaloa_municipios.json"
    as="fetch"
    crossorigin
  />
  <MatrixBackground
    movementDirection="up-left"
    movementSpeed={0.04}
    highlight={false}
    slot="bg"
  />
  <HeroSection cityCounts={cityCounts} />
  <CategorySection counts={counts} />
  <FeaturedSection entries={featured} />
  <MapSection
    cityCounts={cityCounts}
    cityTypeCounts={cityTypeCounts}
    client:visible
  />
  <CalendarSection />
  <CtaSection />
</BaseLayout>
