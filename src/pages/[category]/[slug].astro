---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntryBadge from "../../components/EntryBadge.astro";
import {
  getMunicipalityName,
  CATEGORY_URL_MAP,
  URL_CATEGORY_MAP,
  type AtlasEntryType,
} from "../../config";
import { BadgeCheck, ExternalLink, Globe, MapPin } from "@lucide/astro";

export async function getStaticPaths() {
  const entries = await getCollection("atlas");
  return entries.map((entry) => ({
    params: {
      category: CATEGORY_URL_MAP[entry.data.entryType as AtlasEntryType],
      slug: entry.slug,
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const typeLabels: Record<string, string> = {
  startup: "STARTUPS",
  consultory: "CONSULTORAS",
  community: "COMUNIDADES",
  person: "PERSONAS",
  business: "EMPRESAS",
};

const details: { label: string; value: string | number | undefined }[] = [
  { label: "Categoria", value: typeLabels[entry.data.entryType] },
  { label: "Fundada", value: entry.data.foundedYear },
  { label: "Equipo", value: entry.data.teamSize },
  { label: "Etapa", value: entry.data.stage },
  { label: "Sector", value: entry.data.sector },
  { label: "Miembros", value: entry.data.memberCount },
  { label: "Frecuencia", value: entry.data.meetupFrequency },
  { label: "Rol", value: entry.data.role },
  { label: "Empresa", value: entry.data.company },
].filter((d) => d.value !== undefined);

const links: { label: string; url: string | undefined; icon: string }[] = [
  { label: "Sitio web", url: entry.data.website, icon: "globe" },
  {
    label: "Twitter",
    url: entry.data.twitter
      ? `https://twitter.com/${entry.data.twitter}`
      : undefined,
    icon: "twitter",
  },
  { label: "LinkedIn", url: entry.data.linkedin, icon: "linkedin" },
  {
    label: "GitHub",
    url: entry.data.github
      ? `https://github.com/${entry.data.github}`
      : undefined,
    icon: "github",
  },
  { label: "Discord", url: entry.data.discord, icon: "discord" },
  { label: "Telegram", url: entry.data.telegram, icon: "telegram" },
].filter((l) => l.url !== undefined);
---

<BaseLayout title={`${entry.data.name} — TECH_ATLAS`}>
  {/* Cover image */}
  <div class="w-full h-48 md:h-60 bg-elevated relative overflow-hidden">
    {
      entry.data.coverImage ? (
        <Image
          src={entry.data.coverImage}
          alt={entry.data.name}
          class="w-full h-full object-cover"
          widths={[640, 1024, 1440]}
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-elevated to-card">
          <span class="text-6xl font-mono text-muted/20 font-bold">
            {entry.data.name.charAt(0).toUpperCase()}
          </span>
        </div>
      )
    }
  </div>

  <div class="max-w-7xl mx-auto px-4 py-8">
    {/* Breadcrumb */}
    <nav class="text-xs font-mono text-muted mb-6">
      <a href="/" class="hover:text-accent transition-colors">INICIO</a>
      <span class="mx-2">/</span>
      <a href="/directorio" class="hover:text-accent transition-colors"
        >DIRECTORIO</a
      >
      <span class="mx-2">/</span>
      <a
        href={`/directorio#type=${entry.data.entryType}`}
        class="hover:text-accent transition-colors"
      >
        {typeLabels[entry.data.entryType]}
      </a>
      <span class="mx-2">/</span>
      <span class="text-primary">{entry.data.name.toUpperCase()}</span>
    </nav>

    <div class="grid lg:grid-cols-[1fr_320px] gap-8">
      {/* Left column */}
      <div class="space-y-8">
        {/* Header */}
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            {
              entry.data.logo && (
                <Image
                  src={entry.data.logo}
                  alt={`${entry.data.name} logo`}
                  width={56}
                  height={56}
                  class="w-14 h-14 rounded-lg border border-border object-cover"
                />
              )
            }
            <div>
              <div class="flex items-center gap-2 mb-1">
                <EntryBadge type={entry.data.entryType} />
                {
                  entry.data.verified && (
                    <span class="inline-flex items-center gap-1 text-xs font-mono text-accent">
                      <BadgeCheck class="w-3 h-3" />
                      Verificado
                    </span>
                  )
                }
              </div>
              <h1 class="text-2xl md:text-3xl font-sans font-bold text-primary">
                {entry.data.name}
              </h1>
            </div>
          </div>

          {
            entry.data.tagline && (
              <p class="text-lg text-secondary">{entry.data.tagline}</p>
            )
          }

          {/* Action buttons */}
          <div class="flex flex-wrap gap-3">
            {
              entry.data.website && (
                <a
                  href={entry.data.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 py-2 bg-accent text-accent-foreground font-mono font-semibold text-sm rounded-lg hover:bg-accent/90 transition-colors"
                >
                  VISITAR SITIO
                  <ExternalLink class="w-4 h-4" />
                </a>
              )
            }
          </div>
        </div>

        {/* About */}
        <div
          class="bg-card/90 backdrop-blur-sm border border-border rounded-lg p-6"
        >
          <h2
            class="font-mono text-xs text-muted uppercase tracking-wider mb-4"
          >
            Acerca de
          </h2>
          <div
            class="prose prose-sm dark:prose-invert prose-p:text-secondary prose-headings:text-primary prose-a:text-accent max-w-none"
          >
            <Content />
          </div>
        </div>

        {/* Tags */}
        {
          entry.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {entry.data.tags.map((tag) => (
                <span class="text-xs font-mono px-2 py-1 rounded bg-elevated border border-border text-muted">
                  {tag}
                </span>
              ))}
            </div>
          )
        }

        {/* Skills (person type) */}
        {
          entry.data.skills && entry.data.skills.length > 0 && (
            <div class="bg-card/90 backdrop-blur-sm border border-border rounded-lg p-6">
              <h2 class="font-mono text-xs text-muted uppercase tracking-wider mb-4">
                Habilidades
              </h2>
              <div class="flex flex-wrap gap-2">
                {entry.data.skills.map((skill) => (
                  <span class="text-xs font-mono px-2 py-1 rounded bg-accent/10 text-accent border border-accent/20">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          )
        }
      </div>

      {/* Right column */}
      <div class="space-y-4">
        {/* Details card */}
        {
          details.length > 0 && (
            <div class="bg-card/90 backdrop-blur-sm border border-border rounded-lg p-5">
              <h3 class="font-mono text-xs text-muted uppercase tracking-wider mb-4">
                Detalles
              </h3>
              <div class="space-y-3">
                {details.map((detail) => (
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-muted">{detail.label}</span>
                    <span class="text-sm font-mono text-primary">
                      {detail.value}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          )
        }

        {/* Location card */}
        <div
          class="bg-card/90 backdrop-blur-sm border border-border rounded-lg p-5"
        >
          <h3
            class="font-mono text-xs text-muted uppercase tracking-wider mb-4"
          >
            Ubicacion
          </h3>
          <div class="flex items-center gap-2 text-sm text-primary">
            <MapPin class="w-4 h-4 text-accent shrink-0" />
            <span
              >{
                entry.data.municipality === "global"
                  ? entry.data.city
                  : `${entry.data.city}, ${getMunicipalityName(entry.data.municipality)}`
              }</span
            >
          </div>
          <p class="text-xs text-muted mt-1 ml-6">
            {entry.data.state}, {entry.data.country}
          </p>
        </div>

        {/* Links card */}
        {
          links.length > 0 && (
            <div class="bg-card/90 backdrop-blur-sm border border-border rounded-lg p-5">
              <h3 class="font-mono text-xs text-muted uppercase tracking-wider mb-4">
                Enlaces
              </h3>
              <div class="space-y-2">
                {links.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 text-sm text-secondary hover:text-accent transition-colors"
                  >
                    <ExternalLink class="w-4 h-4" />
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </div>
</BaseLayout>
