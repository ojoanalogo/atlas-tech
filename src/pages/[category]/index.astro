---
import { getCollection } from "astro:content";
import DirectoryLayout from "../../layouts/DirectoryLayout.astro";
import {
  ENTRY_TYPE_CONFIG,
  URL_CATEGORY_MAP,
  type AtlasEntryType,
} from "../../config";

export function getStaticPaths() {
  return Object.entries(URL_CATEGORY_MAP).map(([urlSlug, entryType]) => ({
    params: { category: urlSlug },
    props: { entryType },
  }));
}

const { entryType } = Astro.props as { entryType: AtlasEntryType };
const config = ENTRY_TYPE_CONFIG[entryType];

const allEntries = await getCollection("atlas");
const categoryEntries = allEntries.filter(
  (entry) => entry.data.entryType === entryType,
);
---

<DirectoryLayout
  title={`${config.labelPlural} — TECH_ATLAS`}
  entries={allEntries}
  cityEntries={categoryEntries}
  initialType={entryType}
/>
