---
import BaseLayout from "./BaseLayout.astro";
import EntryCard from "../components/entries/EntryCard.astro";
import DirectoryFilter from "../components/entries/DirectoryFilter";
import {
  DEFAULT_PAGINATION,
  ENTRY_TYPE_CONFIG,
  type AtlasEntryType,
} from "../config";
import { buildCityOptions } from "../utils/cityCounts";
import type { CollectionEntry } from "astro:content";

interface Props {
  title: string;
  /** All entries — rendered in the grid (DOM-filtered client-side) */
  entries: CollectionEntry<"atlas">[];
  /** Entries used to compute city counts (may be a subset, e.g. category-scoped) */
  cityEntries: CollectionEntry<"atlas">[];
  initialType?: string;
  initialCity?: string;
  /** Number of entries per page. 0 = show all (default) */
  pageSize?: number;
}

const {
  title,
  entries,
  cityEntries,
  initialType,
  initialCity,
  pageSize = DEFAULT_PAGINATION,
} = Astro.props;

const typeLabels: Record<string, string> = Object.fromEntries(
  Object.entries(ENTRY_TYPE_CONFIG).map(([k, v]) => [k, v.labelPlural]),
);

const typeIcons: Record<string, string> = Object.fromEntries(
  Object.entries(ENTRY_TYPE_CONFIG).map(([k, v]) => [k, v.icon]),
);

const cities = buildCityOptions(cityEntries);
---

<BaseLayout title={title}>
  <section class="py-4 px-4">
    <div class="max-w-7xl mx-auto">
      <DirectoryFilter
        client:load
        typeLabels={typeLabels}
        typeIcons={typeIcons}
        cities={cities}
        totalCount={entries.length}
        initialType={initialType}
        initialCity={initialCity}
        pageSize={pageSize}
      >
        <div id="entries-grid" class="grid sm:grid-cols-2 xl:grid-cols-3 gap-4">
          {
            entries.map((entry) => (
              <div
                class="entry-item"
                data-type={entry.data.entryType}
                data-city={entry.data.city}
                data-name={entry.data.name.toLowerCase()}
                data-date={
                  entry.data.publishDate?.toISOString().slice(0, 10) ?? ""
                }
              >
                <EntryCard
                  slug={entry.slug}
                  name={entry.data.name}
                  tagline={entry.data.tagline}
                  entryType={entry.data.entryType}
                  logo={entry.data.logo}
                  coverImage={entry.data.coverImage}
                  city={entry.data.city}
                  tags={entry.data.tags}
                />
              </div>
            ))
          }
        </div>
      </DirectoryFilter>
    </div>
  </section>
</BaseLayout>
